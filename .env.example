# KVL Super AI Chatbot — Backend environment template
# Copy to .env for local development. The Installer generates a real .env
# automatically during Step 4 (Configuration) — do not hand-edit secrets.

NODE_ENV=development
PORT=4000
INSTALLER_PORT=4500

# PostgreSQL — app connection, generated automatically by Step 4 (Configuration)
DATABASE_URL=postgresql://kvl_user:kvl_password@localhost:5432/kvl_super_ai_chatbot

# PostgreSQL — admin/superuser connection, used ONLY by Step 6 to CREATE ROLE / CREATE
# DATABASE. Not needed when the installer runs as root on a real VPS (it uses
# `sudo -u postgres psql` instead). Required for non-root environments (e.g. local dev).
DATABASE_ADMIN_URL=

# Redis
REDIS_URL=redis://localhost:6379/0

# Generated by the Installer (Step 5 — Security). Placeholders only for local dev.
JWT_SECRET=
ENCRYPTION_KEY=
API_SECRET=
WEBHOOK_SECRET=
CSRF_SECRET=
COOKIE_SECRET=
SESSION_SECRET=

APPLICATION_ID=
INSTALLATION_ID=

# Phase 8 — Enterprise AI Live Chat Engine. LLM_PROVIDER selects which
# backend generates chat replies; see docs/CHAT_ENGINE.md.
#
# "anthropic"        — cloud, requires ANTHROPIC_API_KEY. LLM_MODEL
#                       defaults to "claude-sonnet-5" if unset.
# "openai_compatible" — fully self-hosted (Ollama/vLLM/LM Studio/any
#                       OpenAI-shaped endpoint), requires LLM_BASE_URL.
#                       LLM_MODEL defaults to "llama3.1:8b-instruct" if
#                       unset. LLM_API_KEY is optional — most local
#                       servers (Ollama) ignore it; some (vLLM with
#                       --api-key) require it.
LLM_PROVIDER=anthropic
LLM_MODEL=
ANTHROPIC_API_KEY=
LLM_BASE_URL=
LLM_API_KEY=

# Phase 10 — Enterprise Automatic Website Update Engine. Email notification
# delivery is opt-in infrastructure: leaving SMTP_HOST unset simply means
# EMAIL is never offered as a channel (Dashboard/Log always work with no
# configuration). WEBHOOK_SECRET above (already generated at install) both
# signs outbound webhook notifications and verifies the inbound
# webhook-triggered-scan endpoint; no separate secret needed. See
# docs/AUTO_UPDATE_ENGINE.md.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
