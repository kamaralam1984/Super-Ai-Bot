node_modules/
dist/
build/
*.log
logs/*.log
.env
.env.*
!.env.example
# Anchored to the repo root (leading /) — these are RUNTIME_DIRECTORIES
# (backend/src/config/paths.ts), created at the repo root by the
# installer for actual application data. Unanchored, these same names
# also matched *source* directories sharing the name at any depth
# (backend/src/config/, backend/src/knowledge/,
# backend/src/deployment/plugins/) and silently excluded real code from
# every commit — caught only because a from-scratch Docker build (which
# has nothing but what git actually tracked) failed with dozens of
# "Cannot find module" errors for modules that plainly exist on disk.
/storage/
/cache/
/uploads/
/temp/
/backups/
/models/
/embeddings/
/knowledge/
/plugins/
/connectors/
/config/

# vectorStore.ts's default storage dir is process.cwd()-relative (not
# APP_ROOT-relative like every other RUNTIME_DIRECTORIES entry above), so
# in practice it lands under backend/ (backend/'s own cwd in both `tsx
# watch` dev and the Docker image's WORKDIR) rather than at the repo
# root — anchoring /storage/ above doesn't catch this one.
backend/storage/
*.tsbuildinfo
.DS_Store
coverage/
prisma/*.db
installer.log
*.traineddata
